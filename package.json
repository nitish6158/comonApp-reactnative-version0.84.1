  "name": "commonapp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start --reset-cache",
    "postinstall": "patch-package && node scripts/patch-react-native-calendars.js && node scripts/patch-native-deps.js",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx",
    "lint:src": "yarn lint App.tsx types/ src/",
    "lint:fix": "yarn lint:src --fix",
    "lint:ts": "tsc --project tsconfig.json",
    "codegen": "rm -rf src/graphql/generated && graphql-codegen --config codegen.yml",
    "test": "jest",
    "create:Module": "npx create-react-native-library@latest new-package --local",
    "build:ios": "react-native bundle --entry-file='index.js' --bundle-output='./ios/main.jsbundle' --dev=false --platform='ios'",
    "assembleDebug": "cd android && ./gradlew clean && cd .. && npx react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res && cd android && ./gradlew assembleDebug",
    "bundleRelease": "cd android && ./gradlew clean && cd .. && npx react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res && cd android && ./gradlew bundleRelease",
    "assembleRelease": "cd android && ./gradlew clean && cd .. && npx react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res && cd android && ./gradlew assembleRelease",
    "debugBuild": "cd android && ./gradlew clean && cd .. && npx react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res && cd android && ./gradlew assembleDebug",
    "androidReleaseAPK": "yarn android --mode release",
    "release": "cd android && ./gradlew clean && cd .. && npx react-native bundle --platform android --dev false  --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res/ && rm -rf ./android/app/src/main/res/drawable-* && rm -rf ./android/app/src/main/res/raw/ && cd ./android && ./gradlew bundleRelease",
    "rm": "rm -rf ./android/app/src/main/res/drawable-* && rm -rf ./android/app/src/main/res/raw"
  },
